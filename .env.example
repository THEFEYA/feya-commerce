# Supabase public read-only client
# Get these from Supabase Project Settings → API.
# Do not commit .env.local with real values.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Never expose service role keys in browser code.
SUPABASE_SERVICE_ROLE_KEY=

# Server-only internal health/check variables. Do not prefix with NEXT_PUBLIC_.
OPENAI_API_KEY=
# Optional small model override for /api/internal/seo-keyword-cleanup.
OPENAI_SEO_CLEANUP_MODEL=
FEYA_INTERNAL_API_TOKEN=
