# FEYA Commerce environment example
# Copy to .env.local for local development.
# Never commit real secrets.

# Supabase public read-only client
# Get these from Supabase Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase server-only service client
# Required for server API routes that create checkout/order drafts.
# Never expose this value in client components or NEXT_PUBLIC variables.
SUPABASE_SERVICE_ROLE_KEY=

# Site URL used for redirects, future payment callbacks and emails
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Future secure payment provider settings
# Do not activate real payment until provider choice, webhook and order-finalization flow are approved.
PAYMENT_PROVIDER=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# Operational emails
FEYA_ORDER_NOTIFICATION_EMAIL=
FEYA_SUPPORT_EMAIL=
